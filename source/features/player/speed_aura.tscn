code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled, fog_disabled;

uniform sampler2D color_trail : source_color;
uniform vec2 speed_trail;
uniform sampler2D tex_frg_2;
uniform float trail_transparency;



void fragment() {
	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(color_trail, UV);
	float n_out8p4 = n_out8p0.a;


// Input:4
	float n_out4p0 = TIME;


// Vector2Parameter:6
	vec2 n_out6p0 = speed_trail;


// VectorOp:5
	vec2 n_out5p0 = vec2(n_out4p0) * n_out6p0;


// UVFunc:3
	vec2 n_in3p1 = vec2(1.00000, 1.00000);
	vec2 n_out3p0 = n_out5p0 * n_in3p1 + UV;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out3p0);
	float n_out2p2 = n_out2p0.g;


// FloatOp:9
	float n_out9p0 = n_out8p4 * n_out2p2;


// FloatParameter:11
	float n_out11p0 = trail_transparency;


// FloatOp:10
	float n_out10p0 = n_out9p0 * n_out11p0;


// Output:0
	ALBEDO = vec3(n_out8p0.xyz);
	ALPHA = n_out10p0;


}
"
