[connection signal="pressed" from="PauseTab/SettingsButton" to="." method="open_settings"]
[connection signal="mouse_entered" from="PauseTab/MainMenuButton" to="PauseTab/MainMenuButton" method="grab_focus" flags=3]
[connection signal="pressed" from="PauseTab/MainMenuButton" to="." method="open_quit_to_menu"]
[connection signal="mouse_entered" from="PauseTab/RetryButton" to="PauseTab/RetryButton" method="grab_focus" flags=3]
[connection signal="pressed" from="PauseTab/RetryButton" to="." method="request_retry"]

