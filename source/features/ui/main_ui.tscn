[sub_resource type="GDScript" id="GDScript_mymm8"]
script/source = "extends AudioStreamPlayer

@onready var music: AudioStreamPlaybackInteractive = self.get_stream_playback()

func _on_ui_time_zone_changed_to(new_time_zone: Variant) -> void:
	if new_time_zone == \"UNSAFE\":
		music.switch_to_clip_by_name(&\"ingame_soundtrack_part_2\")
"

