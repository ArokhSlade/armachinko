[layer_names]

3d_physics/layer_1="everything"
3d_physics/layer_2="player"
3d_physics/layer_3="explosion_blast"
3d_physics/layer_4="tumbleweed"
3d_physics/layer_5="shotgun_blast"
3d_physics/layer_6="explodable"
3d_physics/layer_7="shootable"

[rendering]

renderer/rendering_method.mobile="gl_compatibility"
