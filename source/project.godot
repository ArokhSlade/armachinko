; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Armachinko"
run/main_scene="res://features/ui/menu/title_screen.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
boot_splash/bg_color=Color(0.0562916, 0.0562916, 0.0562916, 1)
boot_splash/image="res://assets/2d/sprites/ui/2d_sprites/S4G-logo.png"
boot_splash/fullsize=false
config/icon="res://icon.svg"
config/tooltip_position_offset=Vector2(10, 10)
config/custom_image=""

[audio]

buses/default_bus_layout="res://assets/sound/default_bus_layout.tres"

[autoload]

PlayerData="*res://features/save_and_load/player_data.tscn"
Globals="*res://features/_globals/globals.gd"
SettingsData="*res://features/_globals/settings_data.tscn"

[display]

window/size/mode=2
window/stretch/mode="canvas_items"
mouse_cursor/custom_image_hotspot=Vector2(27, 27)

[editor_plugins]

enabled=PackedStringArray("res://addons/armachinko_plugin/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "orange",
"res://features/": "blue"
}

[global_group]

Platforms=""
Players=""
ShootHitboxes=""
Tumbleweeds=""
TumbleweedSpawners=""
Coins=""
Enemies=""
ExplosionPins=""
CactusBumpers=""
Eagle=""
Blockout=""

[importer_defaults]

texture={
"compress/high_quality": true,
"compress/mode": 2
}

