[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx;

uniform vec2 Cloud_Speed;
uniform sampler2D tex_vtx_5;
uniform float Cloud_Intensity;
uniform vec4 Albedo : source_color;
uniform vec2 Spritesheet_Frames = vec2(12.000000, 1.000000);
instance uniform int Frame : hint_range(0, 11) = 0;
uniform sampler2D Texture2DParameter : source_color, hint_default_transparent, filter_linear_mipmap_anisotropic;
uniform float Roughness;
uniform vec4 Emission_Color : source_color = vec4(0.958000, 0.500450, 0.394414, 1.000000);
uniform float Emission_Dissolve;
uniform sampler2D tex_frg_21;



void vertex() {
// Input:2
	vec3 n_out2p0 = VERTEX;


// Input:3
	vec3 n_out3p0 = NORMAL;


// Input:9
	float n_out9p0 = TIME;


// Vector2Parameter:14
	vec2 n_out14p0 = Cloud_Speed;


// VectorOp:12
	vec3 n_out12p0 = vec3(n_out9p0) * vec3(n_out14p0, 0.0);


// UVFunc:8
	vec2 n_in8p1 = vec2(1.00000, 1.00000);
	vec2 n_out8p0 = vec2(n_out12p0.xy) * n_in8p1 + UV;


// Texture2D:5
	vec4 n_out5p0 = texture(tex_vtx_5, n_out8p0);
	float n_out5p1 = n_out5p0.r;


// FloatParameter:13
	float n_out13p0 = Cloud_Intensity;


// FloatOp:7
	float n_out7p0 = n_out5p1 * n_out13p0;


// VectorOp:11
	vec3 n_out11p0 = n_out3p0 * vec3(n_out7p0);


// VectorOp:4
	vec3 n_out4p0 = n_out2p0 + n_out11p0;


// Output:0
	VERTEX = n_out4p0;


}

void fragment() {
// ColorParameter:28
	vec4 n_out28p0 = Albedo;


// Vector2Parameter:11
	vec2 n_out11p0 = Spritesheet_Frames;


// IntParameter:10
	int n_out10p0 = Frame;


// Input:14
	vec2 n_out14p0 = UV;


	vec2 n_out8p0;
// Expression:8
	n_out8p0 = vec2(0.0, 0.0);
	{
		float w = 1.0 / n_out11p0.x;
		float h = 1.0 / n_out11p0.y;
		
		int pos_x = int(mod(float(n_out10p0), n_out11p0.x));
		int pos_y = n_out10p0 / int(n_out11p0.x);
		
		n_out8p0.x = (n_out14p0.x / n_out11p0.x) + (float(pos_x) * w);
		n_out8p0.y = (n_out14p0.y / n_out11p0.y) + (float(pos_y) * h);
	}


	vec4 n_out9p0;
// Texture2D:9
	n_out9p0 = texture(Texture2DParameter, n_out8p0);
	float n_out9p1 = n_out9p0.r;


// FloatParameter:16
	float n_out16p0 = Roughness;


// ColorParameter:2
	vec4 n_out2p0 = Emission_Color;


// FloatConstant:3
	float n_out3p0 = 20.000000;


// VectorOp:4
	vec3 n_out4p0 = vec3(n_out2p0.xyz) * vec3(n_out3p0);


// FloatParameter:26
	float n_out26p0 = Emission_Dissolve;


// Input:23
	float n_out23p0 = TIME;


// FloatOp:24
	float n_in24p1 = 0.10000;
	float n_out24p0 = n_out23p0 * n_in24p1;


// UVFunc:25
	vec2 n_in25p1 = vec2(1.00000, 1.00000);
	vec2 n_out25p0 = vec2(n_out24p0) * n_in25p1 + UV;


// Texture2D:21
	vec4 n_out21p0 = texture(tex_frg_21, n_out25p0);


// SmoothStep:22
	float n_in22p1 = 1.00000;
	float n_out22p0 = smoothstep(n_out26p0, n_in22p1, n_out21p0.x);


// VectorOp:20
	vec3 n_out20p0 = n_out4p0 * vec3(n_out22p0);


// Output:0
	ALBEDO = vec3(n_out28p0.xyz);
	ALPHA = n_out9p1;
	ROUGHNESS = n_out16p0;
	EMISSION = n_out20p0;


}
