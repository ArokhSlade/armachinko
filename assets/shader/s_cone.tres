[sub_resource type="VisualShaderNodeVec2Parameter" id="VisualShaderNodeVec2Parameter_ma4s2"]
parameter_name = "VertextDistortionPanning"

[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled;

uniform vec2 VertextDistortionPanning;
uniform sampler2D Vertex_Distortion_Noise;
uniform sampler2D tex_frg_11;
uniform sampler2D tex_frg_2;
uniform vec2 Dissolve;
uniform float Transparancy;



void vertex() {
// Input:2
	vec3 n_out2p0 = VERTEX;


// Input:3
	vec3 n_out3p0 = NORMAL;


// Vector2Parameter:9
	vec2 n_out9p0 = VertextDistortionPanning;


// UVFunc:8
	vec2 n_in8p2 = vec2(0.06000, -0.28000);
	vec2 n_out8p0 = n_in8p2 * n_out9p0 + UV;


	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(Vertex_Distortion_Noise, n_out8p0);


// FloatOp:6
	float n_in6p1 = 2.00000;
	float n_out6p0 = n_out5p0.x * n_in6p1;


// VectorOp:7
	vec3 n_out7p0 = n_out3p0 * vec3(n_out6p0);


// VectorOp:4
	vec3 n_out4p0 = n_out2p0 + n_out7p0;


// Output:0
	VERTEX = n_out4p0;


}

void fragment() {
// Texture2D:11
	vec4 n_out11p0 = texture(tex_frg_11, UV);


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);
	float n_out2p1 = n_out2p0.r;


// Vector2Parameter:6
	vec2 n_out6p0 = Dissolve;


// FloatOp:9
	float n_out9p0 = n_out2p1 - n_out6p0.x;


// FloatParameter:12
	float n_out12p0 = Transparancy;


// Clamp:10
	float n_in10p1 = 0.00000;
	float n_out10p0 = clamp(n_out9p0, n_in10p1, n_out12p0);


// Output:0
	ALBEDO = vec3(n_out11p0.xyz);
	ALPHA = n_out10p0;
	EMISSION = vec3(n_out10p0);


}
